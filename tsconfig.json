{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@price/cache": ["src/price/cache"],
      "@price/cache/*": ["src/price/cache/*"],
      "@price/provider/binance": ["src/price/provider/binance"],
      "@price/provider/binance/*": ["src/price/provider/binance/*"],
      "@price/provider/shared": ["src/price/provider/shared"],
      "@price/provider/shared/*": ["src/price/provider/shared/*"],
      "@price/stream": ["src/price/stream"],
      "@price/stream/*": ["src/price/stream/*"],
      "@telegram/cmd": ["src/telegram/cmd"],
      "@telegram/cmd/*": ["src/telegram/cmd/*"],
      "@telegram/core": ["src/telegram/core"],
      "@telegram/core/*": ["src/telegram/core/*"],
      "@telegram/notification": ["src/telegram/notification"],
      "@telegram/notification/*": ["src/telegram/notification/*"],
      "@telegram/shared": ["src/telegram/shared"],
      "@telegram/shared/*": ["src/telegram/shared/*"],
      "@trade/trigger": ["src/trade/trigger"],
      "@trade/trigger/*": ["src/trade/trigger/*"],
      "@trade/ingestion": ["src/trade/ingestion"],
      "@trade/ingestion/*": ["src/trade/ingestion/*"],
      "@trade/parsing": ["src/trade/parsing"],
      "@trade/parsing/*": ["src/trade/parsing/*"],
      "@trade/repository": ["src/trade/repository"],
      "@trade/repository/*": ["src/trade/repository/*"],
      "@trade/state": ["src/trade/state"],
      "@trade/state/*": ["src/trade/state/*"],
      "@trade/shared": ["src/trade/shared"],
      "@trade/shared/*": ["src/trade/shared/*"],
      "@trade/history": ["src/trade/history"],
      "@trade/history/*": ["src/trade/history/*"],
      "@trade/statistics": ["src/trade/statistics"],
      "@trade/statistics/*": ["src/trade/statistics/*"],
      "@trade/share-card": ["src/trade/share-card"],
      "@trade/share-card/*": ["src/trade/share-card/*"],
      "@trade/*": ["src/trade/*"],
      "@recovery": ["src/recovery"],
      "@recovery/*": ["src/recovery/*"],
      "@trade/domain": ["src/trade/domain"],
      "@trade/domain/*": ["src/trade/domain/*"],
      "@shared": ["src/shared"],
      "@shared/*": ["src/shared/*"],
      "@config/*": ["src/config/*"]
    }
  }
}