{
  "name": "trading-signal-tracker",
  "version": "1.0.0",
  "description": "Telegram bot that monitors trading signals in real-time. Parses trade setups from messages, tracks price movements via WebSocket, and sends instant notifications when Entry, TP or SL levels are hit. Built with NestJS, DDD, and Hexagonal Architecture.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPatterns=.unit.spec.ts",
    "test:pbt": "jest --testPathPatterns=.pbt.spec.ts",
    "test:integration": "jest --testPathPatterns=.integration.spec.ts",
    "test:e2e": "jest --config ./jest-e2e.config.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-ws": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "better-sqlite3": "^9.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "telegraf": "^4.15.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.3.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.0.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
